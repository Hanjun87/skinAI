{
  "name": "skinai-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "backend"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:api": "npm run dev --workspace=backend",
    "dev:admin": "npm run dev --workspace=apps/admin",
    "dev:backend": "npm run dev --workspace=backend",
    "build:web": "npm run build --workspace=apps/web",
    "build:admin": "npm run build --workspace=apps/admin",
    "build:backend": "npm run build --workspace=backend",
    "lint": "npm run lint --workspaces",
    "clean": "rm -rf apps/*/dist apps/*/.vite packages/*/dist backend/dist"
  }
}
