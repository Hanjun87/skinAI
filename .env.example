# 前端API基础地址（网页本地开发可留空；安卓真机建议配置为后端可访问地址）
VITE_API_BASE_URL=""

# 后端可选外部AI接口配置（用于 external_ai_api provider）
EXTERNAL_AI_ENDPOINT=""
EXTERNAL_AI_API_KEY=""
EXTERNAL_AI_MODEL=""
EXTERNAL_AI_TIMEOUT_MS="20000"
EXTERNAL_AI_SYSTEM_PROMPT=""
EXTERNAL_AI_USER_PROMPT_TEMPLATE=""

# 独立后台管理前端端口与API地址
ADMIN_PORT="8788"
ADMIN_API_BASE_URL="http://localhost:8787"

# PostgreSQL 连接（二选一：DATABASE_URL 或 PG*）
DATABASE_URL=""
PGHOST=""
PGPORT="5432"
PGUSER="postgres"
PGPASSWORD=""
PGDATABASE="postgres"
PGSSLMODE=""
